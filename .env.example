# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-to-32-byte-hex-key-64-chars-long!!

# Google OAuth (create at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# MongoDB Atlas — paste your connection string from Atlas → Connect → Drivers
# Example format (replace username, password, cluster host, and db name):
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.xxxxx.mongodb.net/mail_sender?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/mail_sender?retryWrites=true&w=majority
